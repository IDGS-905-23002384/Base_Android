<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:layout_margin="16dp"
    tools:context=".CalcularDistancia.CalcularDistancia">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:src="@drawable/usuario"
            android:layout_width="120dp"
            android:layout_height="120dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            android:text="Distancia entre dos puntos"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtX1"
            android:layout_width="323dp"
            android:layout_height="48dp"
            android:hint="Coordenada X1"
            android:ems="10"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:inputType="numberSigned|numberDecimal"/>

        <EditText
            android:id="@+id/edtY1"
            android:layout_width="323dp"
            android:layout_height="48dp"
            android:hint="Coordenada Y1"
            android:ems="10"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:inputType="numberSigned|numberDecimal"
            android:layout_marginTop="8dp"/>

        <EditText
            android:id="@+id/edtX2"
            android:layout_width="323dp"
            android:layout_height="48dp"
            android:hint="Coordenada X2"
            android:ems="10"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:inputType="numberSigned|numberDecimal"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/edtY2"
            android:layout_width="323dp"
            android:layout_height="48dp"
            android:hint="Coordenada Y2"
            android:ems="10"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:inputType="numberSigned|numberDecimal"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnCalcular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calcular Distancia"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/txtResultadoDistancia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Resultado: 0"
            android:textColor="@color/white"
            android:textSize="25sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>